# Google Sheets
GOOGLE_SHEETS_CREDENTIALS_JSON=/app/credentials/service_account.json
GOOGLE_SHEETS_SPREADSHEET_ID=

# Instagram (Graph API)
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# TikTok (Content Posting API)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=

# ASR バックエンド: auto | whisperx | reazonspeech | faster-whisper
# auto は WhisperX を最優先（±50ms の word timestamp でキネティック字幕が正確に出る。
# 失敗時 ReazonSpeech → faster-whisper にフォールバック）。
# 日本語精度の都合で従来挙動に戻したい場合は reazonspeech を指定する。
ASR_BACKEND=auto

# AI Jump Cut (optional - degraded mode if unset)
# LLM_PROVIDER: openai or anthropic
LLM_PROVIDER=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# LLM Coherence Pass (OpenSpec: llm-coherence-pass)
# 既存検出後の生存word列に対し「日本語として意味が通る最小subset」を
# LLM に判定させる追加レイヤー。デフォルト OFF。
# ENABLE_LLM_COHERENCE_PASS=1 で有効化
# LLM_COHERENCE_PASS_DRY_RUN=1 で削除候補のダンプのみ（実カットなし）
ENABLE_LLM_COHERENCE_PASS=0
LLM_COHERENCE_PASS_DRY_RUN=0

# App Settings
PUBLIC_BASE_URL=http://localhost:8000

# ===== 投稿機能 (social-publishing) =====
# DB (docker-compose の Postgres を既定で参照。compose 側で上書き)
DATABASE_URL=postgresql+psycopg2://reel:reel@db:5432/reel
# アップロード動画の保存先（コンテナ内）
MEDIA_DIR=/app/media

# Instagram は外部からアクセス可能な HTTPS URL を要求する。
# ローカル Docker では投稿時に ngrok 等のトンネルを立て、
# PUBLIC_BASE_URL をトンネル URL に設定すること。

# Meta OAuth (Phase 3)
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=

# Google / YouTube OAuth (Phase 2)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
YOUTUBE_CHANNEL_ID=

# 予約実行 cron 手動トリガー保護 (Phase 4)
CRON_SECRET=
# 連携トークン暗号化キー (Fernet, Phase 2+)。生成: python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=
