# Google Sheets
GOOGLE_SHEETS_CREDENTIALS_JSON=/app/credentials/service_account.json
GOOGLE_SHEETS_SPREADSHEET_ID=

# Instagram (Graph API)
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# TikTok (Content Posting API)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=

# AI Jump Cut (optional - degraded mode if unset)
# LLM_PROVIDER: openai or anthropic
LLM_PROVIDER=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# LLM Coherence Pass (OpenSpec: llm-coherence-pass)
# 既存検出後の生存word列に対し「日本語として意味が通る最小subset」を
# LLM に判定させる追加レイヤー。デフォルト OFF。
# ENABLE_LLM_COHERENCE_PASS=1 で有効化
# LLM_COHERENCE_PASS_DRY_RUN=1 で削除候補のダンプのみ（実カットなし）
ENABLE_LLM_COHERENCE_PASS=0
LLM_COHERENCE_PASS_DRY_RUN=0

# App Settings
PUBLIC_BASE_URL=http://localhost:8000
