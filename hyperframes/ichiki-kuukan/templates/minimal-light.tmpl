<!doctype html>
<html lang="ja" data-resolution="portrait">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reel — minimal-light</title>
    <!-- テンプレート。値は brief.json で編集（template: "minimal-light"）し `npm run build`。 -->
    <!-- 明るいエディトリアル調: footage の上にクリーム(ivory)帯を敷き、濃色(bg)の明朝文字を乗せる。 -->
    <script src="https://cdn.jsdelivr.net/npm/gsap@3.14.2/dist/gsap.min.js"></script>
    <style>
      :root {
        --ivory: {{ivory}};
        --accent: {{accent}};
        --rule: {{rule}};
        --romaji: {{romaji_color}};
        --bg: {{bg}};
      }
      * { margin: 0; padding: 0; box-sizing: border-box; }

      @font-face {
        font-family: "Shippori Mincho"; font-style: normal; font-weight: 700; font-display: block;
        src: url("fonts/shippori-mincho-latin-700.woff2") format("woff2");
        unicode-range: U+0000-00FF,U+2000-20CF,U+2100-214F;
      }
      @font-face {
        font-family: "Shippori Mincho"; font-style: normal; font-weight: 700; font-display: block;
        src: url("fonts/shippori-mincho-jp-700.woff2") format("woff2");
        unicode-range: U+3000-30FF,U+3400-4DBF,U+4E00-9FFF,U+FF00-FFEF,U+31F0-31FF;
      }
      @font-face {
        font-family: "Zen Kaku Gothic New"; font-style: normal; font-weight: 400; font-display: block;
        src: url("fonts/zen-kaku-latin-400.woff2") format("woff2");
        unicode-range: U+0000-00FF,U+2000-20CF,U+2100-214F;
      }
      @font-face {
        font-family: "Zen Kaku Gothic New"; font-style: normal; font-weight: 400; font-display: block;
        src: url("fonts/zen-kaku-jp-400.woff2") format("woff2");
        unicode-range: U+3000-30FF,U+3400-4DBF,U+4E00-9FFF,U+FF00-FFEF,U+31F0-31FF;
      }

      body, html { width: 1080px; height: 1920px; overflow: hidden; background: var(--bg); }
      #main-composition { position: relative; width: 1080px; height: 1920px; overflow: hidden; }
      #kenburns { position: absolute; inset: 0; width: 100%; height: 100%; transform-origin: 50% 42%; }
      #a-roll { width: 1080px; height: 1920px; object-fit: cover; display: block; }

      /* ほんのり明るく整える（重い暗幕は使わない） */
      .wash { position:absolute; inset:0; background: rgba(244,237,224,0.10); pointer-events:none; }
      .vignette { position:absolute; inset:0; pointer-events:none; box-shadow: inset 0 0 260px 40px rgba(0,0,0,0.30); }

      .serif { font-family: "Shippori Mincho", serif; }
      .gothic { font-family: "Zen Kaku Gothic New", sans-serif; }

      /* クリーム帯 + 濃色文字（エディトリアル） */
      .band {
        position:absolute; left: 70px; right: 70px;
        background: rgba(244,237,224,0.93); /* ivory */
        backdrop-filter: blur(2px);
        padding: 56px 60px; text-align:center;
        box-shadow: 0 24px 60px rgba(0,0,0,0.28);
      }
      .hair { width: 56px; height: 1.5px; background: var(--bg); opacity:0.5; margin: 0 auto; }

      /* intro */
      .intro { top: 690px; }
      .wordmark { font-size: 116px; font-weight:700; letter-spacing: 0.1em; color: var(--bg); line-height:1.0; }
      .romaji { margin-top: 22px; font-size: 26px; font-weight:400; letter-spacing: 0.52em; color: #6b6256; padding-left:0.52em; }
      .intro .hair { margin-top: 30px; }

      /* phrase */
      .pband { top: 720px; }
      .phrase { font-size: 70px; font-weight:700; line-height: 1.6; letter-spacing: 0.06em; color: var(--bg); }
      .phrase em { font-style: normal; color: #9a7b32; } /* 落ち着いたゴールド系（濃色帯向け） */

      /* outro */
      .oband { bottom: 250px; }
      .kicker { font-size: 25px; font-weight:400; letter-spacing: 0.44em; color: #6b6256; padding-left:0.44em; margin-bottom: 18px; }
      .handle { font-size: 52px; font-weight:700; letter-spacing: 0.12em; color: var(--bg); }
    </style>
  </head>
  <body>
    <div id="main-composition" data-composition-id="main-video" data-width="1080" data-height="1920" data-start="0" data-duration="12">
      <div id="kenburns">
        <video id="a-roll" src="{{footage}}" muted playsinline data-start="0" data-duration="12" data-track-index="0"></video>
      </div>

      <div id="overlays" class="clip" data-start="0" data-duration="12" data-track-index="1" style="position:absolute; inset:0;">
        <div class="wash"></div>
        <div class="vignette"></div>

        <!-- Scene 1: intro -->
        <div class="band intro" id="s1">
          <div class="wordmark serif">{{wordmark}}</div>
          <div class="romaji gothic">{{romaji}}</div>
          <div class="hair"></div>
        </div>

        <!-- Scene 2: phrase 1 -->
        <div class="band pband" id="s2">
          <div class="phrase serif">{{phrase1}}</div>
        </div>

        <!-- Scene 3: phrase 2 -->
        <div class="band pband" id="s3">
          <div class="phrase serif">{{phrase2}}</div>
        </div>

        <!-- Scene 4: outro -->
        <div class="band oband" id="s4">
          <div class="kicker gothic">{{kicker}}</div>
          <div class="handle serif">{{handle}}</div>
        </div>
      </div>

      <script>
        window.__timelines = window.__timelines || {};
        const tl = gsap.timeline({ paused: true });

        gsap.set("#kenburns", { scale: 1.07 });
        tl.to("#kenburns", { scale: 1.0, duration: 12, ease: "none" }, 0);

        // 各 band は下からふわっと（opacity + y + わずかに scale）
        gsap.set(["#s1", "#s2", "#s3", "#s4"], { opacity: 0, y: 34 });

        // Scene 1 (0.0 - 3.2)
        tl.to("#s1", { opacity: 1, y: 0, duration: 0.9, ease: "power2.out" }, 0.3);
        tl.to("#s1", { opacity: 0, duration: 0.55, ease: "power1.in" }, 3.0);

        // Scene 2 (3.4 - 6.4)
        tl.to("#s2", { opacity: 1, y: 0, duration: 0.9, ease: "power2.out" }, 3.4);
        tl.to("#s2", { opacity: 0, duration: 0.55, ease: "power1.in" }, 6.1);

        // Scene 3 (6.6 - 9.4)
        tl.to("#s3", { opacity: 1, y: 0, duration: 0.9, ease: "power2.out" }, 6.7);
        tl.to("#s3", { opacity: 0, duration: 0.55, ease: "power1.in" }, 9.1);

        // Scene 4 outro (9.6 - 12)
        tl.to("#s4", { opacity: 1, y: 0, duration: 0.9, ease: "power2.out" }, 9.7);

        window.__timelines["main-video"] = tl;
      </script>
    </div>
  </body>
</html>
