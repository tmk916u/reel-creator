<!doctype html>
<html lang="ja" data-resolution="portrait">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ICHIKI KUUKAN — Reel</title>
    <!-- このファイルはテンプレートです。値は brief.json で編集し `npm run build` で index.html を生成します。 -->
    <script src="https://cdn.jsdelivr.net/npm/gsap@3.14.2/dist/gsap.min.js"></script>
    <style>
      :root {
        --ivory: {{ivory}};
        --accent: {{accent}};
        --rule: {{rule}};
        --romaji: {{romaji_color}};
        --bg: {{bg}};
      }
      * { margin: 0; padding: 0; box-sizing: border-box; }

      @font-face {
        font-family: "Shippori Mincho"; font-style: normal; font-weight: 700; font-display: block;
        src: url("fonts/shippori-mincho-latin-700.woff2") format("woff2");
        unicode-range: U+0000-00FF,U+2000-20CF,U+2100-214F;
      }
      @font-face {
        font-family: "Shippori Mincho"; font-style: normal; font-weight: 700; font-display: block;
        src: url("fonts/shippori-mincho-jp-700.woff2") format("woff2");
        unicode-range: U+3000-30FF,U+3400-4DBF,U+4E00-9FFF,U+FF00-FFEF,U+31F0-31FF;
      }
      @font-face {
        font-family: "Zen Kaku Gothic New"; font-style: normal; font-weight: 400; font-display: block;
        src: url("fonts/zen-kaku-latin-400.woff2") format("woff2");
        unicode-range: U+0000-00FF,U+2000-20CF,U+2100-214F;
      }
      @font-face {
        font-family: "Zen Kaku Gothic New"; font-style: normal; font-weight: 400; font-display: block;
        src: url("fonts/zen-kaku-jp-400.woff2") format("woff2");
        unicode-range: U+3000-30FF,U+3400-4DBF,U+4E00-9FFF,U+FF00-FFEF,U+31F0-31FF;
      }
      @font-face {
        font-family: "Zen Kaku Gothic New"; font-style: normal; font-weight: 700; font-display: block;
        src: url("fonts/zen-kaku-latin-700.woff2") format("woff2");
        unicode-range: U+0000-00FF,U+2000-20CF,U+2100-214F;
      }
      @font-face {
        font-family: "Zen Kaku Gothic New"; font-style: normal; font-weight: 700; font-display: block;
        src: url("fonts/zen-kaku-jp-700.woff2") format("woff2");
        unicode-range: U+3000-30FF,U+3400-4DBF,U+4E00-9FFF,U+FF00-FFEF,U+31F0-31FF;
      }

      body, html {
        width: 1080px; height: 1920px; overflow: hidden; background: var(--bg);
      }
      #main-composition { position: relative; width: 1080px; height: 1920px; overflow: hidden; }

      #kenburns { position: absolute; inset: 0; width: 100%; height: 100%; transform-origin: 52% 42%; }
      #a-roll { width: 1080px; height: 1920px; object-fit: cover; display: block; }

      .scrim-top {
        position: absolute; top: 0; left: 0; width: 100%; height: 44%;
        background: linear-gradient(to bottom, rgba(8,8,10,0.62), rgba(8,8,10,0)); pointer-events: none;
      }
      .scrim-bottom {
        position: absolute; bottom: 0; left: 0; width: 100%; height: 50%;
        background: linear-gradient(to top, rgba(8,8,10,0.78), rgba(8,8,10,0)); pointer-events: none;
      }
      .vignette { position: absolute; inset: 0; pointer-events: none; box-shadow: inset 0 0 320px 60px rgba(0,0,0,0.55); }

      @keyframes grain { 0%,100%{transform:translate(0,0)} 20%{transform:translate(-6%,4%)} 40%{transform:translate(5%,-8%)} 60%{transform:translate(8%,3%)} 80%{transform:translate(-7%,0)} }
      .grain {
        position: absolute; top:-50%; left:-50%; width:200%; height:200%;
        background: url("https://www.transparenttextures.com/patterns/natural-paper.png");
        opacity: 0.10; mix-blend-mode: overlay; animation: grain 0.6s steps(1) infinite; pointer-events:none;
      }

      .stage { position: absolute; inset: 0; pointer-events: none; }
      .center { display:flex; flex-direction:column; align-items:center; justify-content:center; width:100%; height:100%; text-align:center; }
      .ivory { color: var(--ivory); }
      .serif { font-family: "Shippori Mincho", serif; }
      .gothic { font-family: "Zen Kaku Gothic New", sans-serif; }

      .wordmark { font-size: 132px; font-weight:700; letter-spacing: 0.14em; text-shadow: 0 4px 30px rgba(0,0,0,0.5); }
      .romaji { margin-top: 30px; font-size: 30px; font-weight:400; letter-spacing: 0.62em; color: var(--romaji); padding-left: 0.62em; }
      .rule { width: 78px; height: 1.5px; background: var(--rule); margin: 44px auto 0; opacity:0.9; }

      .phrase { font-size: 78px; font-weight:700; line-height: 1.7; letter-spacing: 0.08em; text-shadow: 0 4px 28px rgba(0,0,0,0.55); }
      .phrase em { font-style: normal; color: var(--accent); }

      .lower { position:absolute; left:0; right:0; bottom: 168px; text-align:center; }
      .handle { font-size: 46px; font-weight:700; letter-spacing: 0.16em; color: var(--ivory); }
      .kicker { font-size: 27px; font-weight:400; letter-spacing: 0.46em; color: var(--rule); padding-left:0.46em; margin-bottom: 26px; }
      .outrule { width: 120px; height:1.5px; background: var(--rule); margin: 30px auto 0; opacity:0.85; }
    </style>
  </head>
  <body>
    <div id="main-composition" data-composition-id="main-video" data-width="1080" data-height="1920" data-start="0" data-duration="12">
      <!-- footage -->
      <div id="kenburns">
        <video id="a-roll" src="{{footage}}" muted playsinline data-start="0" data-duration="12" data-track-index="0"></video>
      </div>

      <!-- all overlays as ONE clip on track 1 (above footage track 0) -->
      <div id="overlays" class="clip" data-start="0" data-duration="12" data-track-index="1" style="position:absolute; inset:0;">
        <div class="scrim-top"></div>
        <div class="scrim-bottom"></div>
        <div class="vignette"></div>
        <div class="grain"></div>

        <div class="stage" id="s1">
          <div class="center">
            <div class="wordmark serif ivory">{{wordmark}}</div>
            <div class="romaji gothic">{{romaji}}</div>
            <div class="rule" id="s1rule"></div>
          </div>
        </div>

        <div class="stage" id="s2">
          <div class="center">
            <div class="phrase serif ivory">{{phrase1}}</div>
          </div>
        </div>

        <div class="stage" id="s3">
          <div class="center">
            <div class="phrase serif ivory">{{phrase2}}</div>
          </div>
        </div>

        <div class="stage" id="s4">
          <div class="lower">
            <div class="kicker gothic">{{kicker}}</div>
            <div class="handle gothic">{{handle}}</div>
            <div class="outrule"></div>
          </div>
        </div>
      </div>

      <script>
        window.__timelines = window.__timelines || {};
        const tl = gsap.timeline({ paused: true });

        gsap.set("#kenburns", { scale: 1.08 });
        tl.to("#kenburns", { scale: 1.0, duration: 12, ease: "none" }, 0);

        gsap.set(["#s1 .wordmark", "#s1 .romaji"], { opacity: 0, y: 28 });
        gsap.set("#s1rule", { scaleX: 0, transformOrigin: "50% 50%" });
        gsap.set(["#s2 .phrase", "#s3 .phrase"], { opacity: 0, y: 30 });
        gsap.set(["#s4 .kicker", "#s4 .handle"], { opacity: 0, y: 22 });
        gsap.set("#s4 .outrule", { scaleX: 0, transformOrigin: "50% 50%" });

        // Scene 1 (0.0 - 3.2)
        tl.to("#s1 .wordmark", { opacity: 1, y: 0, duration: 1.1, ease: "power2.out" }, 0.3);
        tl.to("#s1 .romaji", { opacity: 1, y: 0, duration: 1.0, ease: "power2.out" }, 0.7);
        tl.to("#s1rule", { scaleX: 1, duration: 0.9, ease: "power2.inOut" }, 1.0);
        tl.to(["#s1 .wordmark", "#s1 .romaji", "#s1rule"], { opacity: 0, duration: 0.6, ease: "power1.in" }, 3.0);

        // Scene 2 (3.4 - 6.6)
        tl.to("#s2 .phrase", { opacity: 1, y: 0, duration: 1.0, ease: "power2.out" }, 3.5);
        tl.to("#s2 .phrase", { opacity: 0, duration: 0.6, ease: "power1.in" }, 6.2);

        // Scene 3 (6.7 - 9.6)
        tl.to("#s3 .phrase", { opacity: 1, y: 0, duration: 1.0, ease: "power2.out" }, 6.8);
        tl.to("#s3 .phrase", { opacity: 0, duration: 0.6, ease: "power1.in" }, 9.2);

        // Scene 4 outro (9.7 - 12)
        tl.to("#s4 .kicker", { opacity: 1, y: 0, duration: 0.9, ease: "power2.out" }, 9.8);
        tl.to("#s4 .handle", { opacity: 1, y: 0, duration: 0.9, ease: "power2.out" }, 10.1);
        tl.to("#s4 .outrule", { scaleX: 1, duration: 0.9, ease: "power2.inOut" }, 10.4);

        window.__timelines["main-video"] = tl;
      </script>
    </div>
  </body>
</html>
